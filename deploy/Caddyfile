# Automatic HTTPS (Let's Encrypt) for calisthenics.betmart.com.br
# Set CADDY_EMAIL in docker-compose (or .env) for the ACME account / expiry notices.

{
    email {$CADDY_EMAIL}
}

sparta.betmart.com.br {
    encode gzip zstd
    handle /api* {
        reverse_proxy api:4000
    }
    handle {
        reverse_proxy web:80
    }
}
