# Used by Caddy for Let's Encrypt account (renewal / issue notices).
# Copy to .env on the server and set a real mailbox you monitor.
CADDY_EMAIL=ssl@betmart.com.br

# Required for docker compose (api service). Use a long random string in production.
JWT_SECRET=change-me-to-a-long-random-secret

# Optional: comma-separated origins for CORS (e.g. https://sparta.betmart.com.br).
# Leave empty to allow any origin (fine behind same-site Caddy + relative /api).
# CORS_ORIGINS=https://sparta.betmart.com.br

# Optional: only if the SPA is served from a different host than the API.
# With Docker + Caddy, the app uses same-origin /api — leave unset for production compose.
# VITE_API_URL=https://your-api-host
